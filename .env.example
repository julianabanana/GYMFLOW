# Copiar a .env y ajustar. Nunca commitear el .env real (ver AGENTS.md, "No expongas .env").

POSTGRES_USER=gymflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=gymflow

# Usado por el backend para firmar los JWT (Staff/Administrador y Miembro).
# Generar uno real para cada entorno, nunca reusar este valor en producción.
JWT_SECRET=dev-secret-change-me
